<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BlendedSkill - Your Project Is Your Resume</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-primary: #FFFFFF;
            --bg-secondary: #FAFAFA;
            --brand-indigo: #4F46E5;
            --brand-indigo-hover: #4338CA;
            --brand-amber: #F59E0B;
            --text-primary: #0A0A0A;
            --text-secondary: #4B5563;
            --text-muted: #9CA3AF;
            --border-light: #E5E7EB;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            --shadow-lg: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            --font-display: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            --font-mono: 'JetBrains Mono', monospace;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: var(--font-display);
            background-color: var(--bg-primary);
            color: var(--text-primary);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
            overflow-x: hidden;
        }

        /* Navigation */
        nav {
            position: sticky;
            top: 0;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--border-light);
            z-index: 1000;
            height: 72px;
        }

        .nav-container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 2rem;
            height: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            text-decoration: none;
            font-weight: 800;
            font-size: 1.5rem;
            color: var(--text-primary);
            letter-spacing: -0.02em;
        }

        .logo-icon {
            width: 36px;
            height: 36px;
            background: var(--brand-indigo);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
        }

        .nav-left {
            display: flex;
            align-items: center;
            gap: 3rem;
        }

        .nav-links {
            display: flex;
            gap: 2rem;
            list-style: none;
        }

        .nav-links a {
            text-decoration: none;
            color: var(--text-secondary);
            font-weight: 500;
            font-size: 0.95rem;
            transition: color 0.2s;
            position: relative;
        }

        .nav-links a:hover {
            color: var(--text-primary);
        }

        .dropdown {
            position: relative;
        }

        .dropdown-content {
            display: none;
            position: absolute;
            top: 100%;
            left: 0;
            background: white;
            border: 1px solid var(--border-light);
            border-radius: 8px;
            box-shadow: var(--shadow-lg);
            padding: 0.5rem 0;
            min-width: 200px;
            margin-top: 0.5rem;
        }

        .dropdown:hover .dropdown-content {
            display: block;
        }

        .dropdown-item {
            padding: 0.75rem 1rem;
            display: block;
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 0.9rem;
        }

        .dropdown-item:hover {
            background: var(--bg-secondary);
            color: var(--text-primary);
        }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }

        .proof-badge {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 1rem;
            background: linear-gradient(135deg, #FEF3C7, #FDE68A);
            border: 1px solid #F59E0B;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 600;
            color: #92400E;
            cursor: pointer;
            transition: transform 0.2s;
        }

        .proof-badge:hover {
            transform: translateY(-1px);
        }

        .proof-icon {
            font-size: 1rem;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            padding: 0.75rem 1.5rem;
            border-radius: 6px;
            font-weight: 600;
            font-size: 0.95rem;
            text-decoration: none;
            transition: all 0.2s;
            border: none;
            cursor: pointer;
            font-family: inherit;
        }

        .btn-primary {
            background-color: var(--brand-indigo);
            color: white;
            box-shadow: var(--shadow-sm);
        }

        .btn-primary:hover {
            background-color: var(--brand-indigo-hover);
            transform: translateY(-1px);
            box-shadow: var(--shadow-md);
        }

        .btn-text {
            color: var(--text-secondary);
            background: none;
            padding: 0.5rem;
        }

        .btn-text:hover {
            color: var(--text-primary);
        }

        .mobile-menu-btn {
            display: none;
            background: none;
            border: none;
            font-size: 1.5rem;
            cursor: pointer;
            color: var(--text-primary);
        }

        /* Hero Section */
        .hero {
            padding: 6rem 2rem 8rem;
            max-width: 1280px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1fr 1.2fr;
            gap: 4rem;
            align-items: center;
            min-height: calc(100vh - 72px);
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 1rem;
            background: #EEF2FF;
            color: var(--brand-indigo);
            border-radius: 20px;
            font-size: 0.875rem;
            font-weight: 600;
            margin-bottom: 1.5rem;
            border: 1px solid #C7D2FE;
        }

        .hero h1 {
            font-size: 56px;
            line-height: 1.1;
            font-weight: 800;
            letter-spacing: -0.02em;
            margin-bottom: 1.5rem;
            color: var(--text-primary);
        }

        .hero-subtitle {
            font-size: 1.25rem;
            color: var(--text-secondary);
            margin-bottom: 2.5rem;
            line-height: 1.7;
            max-width: 540px;
        }

        .hero-cta {
            display: flex;
            gap: 1rem;
            align-items: center;
        }

        .hero-cta .btn-primary {
            padding: 1rem 2rem;
            font-size: 1.05rem;
        }

        .hero-secondary {
            color: var(--text-secondary);
            text-decoration: none;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .hero-secondary:hover {
            color: var(--brand-indigo);
        }

        .hero-visual {
            position: relative;
            background: var(--bg-secondary);
            border-radius: 16px;
            padding: 2rem;
            border: 1px solid var(--border-light);
            box-shadow: var(--shadow-lg);
        }

        .portfolio-mock {
            background: white;
            border-radius: 12px;
            border: 1px solid var(--border-light);
            overflow: hidden;
            box-shadow: var(--shadow-md);
        }

        .portfolio-header {
            background: #F3F4F6;
            padding: 1rem;
            border-bottom: 1px solid var(--border-light);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .portfolio-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: #D1D5DB;
        }

        .portfolio-content {
            padding: 2rem;
            position: relative;
        }

        .process-map {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .process-step {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1rem;
            background: #F9FAFB;
            border-radius: 8px;
            border-left: 4px solid var(--brand-indigo);
        }

        .process-icon {
            width: 40px;
            height: 40px;
            background: white;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid var(--border-light);
            font-size: 1.25rem;
        }

        .graduate-badge {
            position: absolute;
            bottom: -1rem;
            right: -1rem;
            background: white;
            padding: 1rem;
            border-radius: 12px;
            box-shadow: var(--shadow-lg);
            border: 1px solid var(--border-light);
            max-width: 280px;
        }

        .badge-header {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 0.5rem;
            color: var(--brand-amber);
            font-weight: 700;
            font-size: 0.875rem;
        }

        .badge-text {
            font-size: 0.9rem;
            color: var(--text-secondary);
            line-height: 1.5;
        }

        .badge-name {
            font-weight: 700;
            color: var(--text-primary);
        }

        /* Social Proof Section */
        .social-proof {
            background: var(--bg-secondary);
            padding: 6rem 2rem;
            border-top: 1px solid var(--border-light);
        }

        .social-container {
            max-width: 1280px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1fr 1.5fr;
            gap: 4rem;
            align-items: center;
        }

        .social-stat h2 {
            font-size: 40px;
            font-weight: 800;
            letter-spacing: -0.01em;
            margin-bottom: 1.5rem;
            line-height: 1.2;
        }

        .stat-big {
            font-family: var(--font-mono);
            font-size: 4rem;
            color: var(--brand-indigo);
            font-weight: 700;
            display: block;
            margin-bottom: 0.5rem;
        }

        .stat-label {
            font-size: 1.125rem;
            color: var(--text-secondary);
            max-width: 400px;
        }

        .case-studies {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .case-card {
            background: white;
            padding: 2rem;
            border-radius: 12px;
            border: 1px solid var(--border-light);
            box-shadow: var(--shadow-sm);
            transition: all 0.3s;
        }

        .case-card:hover {
            box-shadow: var(--shadow-md);
            transform: translateX(4px);
            border-left: 4px solid var(--brand-indigo);
        }

        .case-header {
            display: flex;
            justify-content: space-between;
            align-items: start;
            margin-bottom: 1rem;
        }

        .case-avatar {
            width: 48px;
            height: 48px;
            background: var(--brand-indigo);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 1.25rem;
        }

        .case-meta {
            text-align: right;
        }

        .case-name {
            font-weight: 700;
            color: var(--text-primary);
        }

        .case-transition {
            font-size: 0.875rem;
            color: var(--brand-indigo);
            font-weight: 600;
        }

        .case-quote {
            font-size: 1.1rem;
            color: var(--text-secondary);
            font-style: italic;
            line-height: 1.6;
            margin-bottom: 1rem;
        }

        .case-course {
            font-size: 0.875rem;
            color: var(--text-muted);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        /* How It Works - Timeline */
        .how-it-works {
            padding: 6rem 2rem;
            max-width: 1280px;
            margin: 0 auto;
        }

        .section-header {
            text-align: center;
            margin-bottom: 4rem;
        }

        .section-header h2 {
            font-size: 40px;
            font-weight: 800;
            letter-spacing: -0.01em;
            margin-bottom: 1rem;
        }

        .section-header p {
            font-size: 1.25rem;
            color: var(--text-secondary);
            max-width: 600px;
            margin: 0 auto;
        }

        .timeline {
            position: relative;
            max-width: 1000px;
            margin: 0 auto;
        }

        .timeline-item {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            margin-bottom: 4rem;
            position: relative;
        }

        .timeline-item:nth-child(even) {
            direction: rtl;
        }

        .timeline-item:nth-child(even) > * {
            direction: ltr;
        }

        .timeline-content h3 {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .step-number {
            font-family: var(--font-mono);
            font-size: 0.875rem;
            color: var(--brand-indigo);
            background: #EEF2FF;
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            border: 1px solid #C7D2FE;
        }

        .timeline-content p {
            color: var(--text-secondary);
            font-size: 1.1rem;
            line-height: 1.7;
        }

        .timeline-visual {
            background: var(--bg-secondary);
            border-radius: 12px;
            padding: 2rem;
            border: 1px solid var(--border-light);
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 200px;
        }

        .verification-highlight {
            background: linear-gradient(135deg, #FEF3C7, #FDE68A);
            border: 2px solid var(--brand-amber);
            border-radius: 8px;
            padding: 1rem;
            margin-top: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .verification-highlight span {
            font-weight: 700;
            color: #92400E;
        }

        .cert-mock {
            width: 100%;
            background: white;
            border: 2px solid var(--border-light);
            border-radius: 8px;
            padding: 1.5rem;
            text-align: center;
            position: relative;
        }

        .cert-seal {
            width: 60px;
            height: 60px;
            background: var(--brand-indigo);
            border-radius: 50%;
            margin: 0 auto 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.5rem;
            box-shadow: 0 4px 6px -1px rgba(79, 70, 229, 0.3);
        }

        .cert-title {
            font-weight: 700;
            font-size: 1.1rem;
            margin-bottom: 0.5rem;
        }

        .cert-project {
            font-family: var(--font-mono);
            font-size: 0.875rem;
            color: var(--brand-indigo);
            background: #EEF2FF;
            padding: 0.5rem;
            border-radius: 4px;
            display: inline-block;
            margin-top: 0.5rem;
        }

        /* Course Catalog */
        .courses {
            background: var(--bg-secondary);
            padding: 6rem 2rem;
        }

        .courses-container {
            max-width: 1280px;
            margin: 0 auto;
        }

        .filter-bar {
            display: flex;
            gap: 1rem;
            margin-bottom: 3rem;
            flex-wrap: wrap;
        }

        .filter-input {
            padding: 0.75rem 1rem;
            border: 1px solid var(--border-light);
            border-radius: 6px;
            font-family: inherit;
            font-size: 0.95rem;
            min-width: 300px;
        }

        .filter-btn {
            padding: 0.75rem 1.5rem;
            border: 1px solid var(--border-light);
            background: white;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 500;
            color: var(--text-secondary);
            transition: all 0.2s;
        }

        .filter-btn:hover, .filter-btn.active {
            background: var(--brand-indigo);
            color: white;
            border-color: var(--brand-indigo);
        }

        .course-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 2rem;
        }

        .course-card {
            background: white;
            border-radius: 12px;
            border: 1px solid var(--border-light);
            padding: 2rem;
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }

        .course-card:hover {
            box-shadow: var(--shadow-lg);
            transform: translateY(-2px);
            border-color: #C7D2FE;
        }

        .course-icon {
            width: 56px;
            height: 56px;
            background: #EEF2FF;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            margin-bottom: 1.5rem;
            color: var(--brand-indigo);
        }

        .course-role {
            font-size: 0.875rem;
            font-weight: 700;
            color: var(--brand-indigo);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 0.5rem;
        }

        .course-title {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 1rem;
            color: var(--text-primary);
        }

        .course-outcome {
            background: #F9FAFB;
            border-left: 3px solid var(--brand-amber);
            padding: 1rem;
            margin-bottom: 1.5rem;
            border-radius: 0 6px 6px 0;
        }

        .course-outcome-label {
            font-size: 0.75rem;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            margin-bottom: 0.25rem;
        }

        .course-outcome-text {
            color: var(--text-secondary);
            font-size: 0.95rem;
            font-weight: 600;
        }

        .course-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
            font-size: 0.875rem;
            color: var(--text-muted);
        }

        .course-link {
            color: var(--brand-indigo);
            text-decoration: none;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .course-link:hover {
            gap: 0.75rem;
        }

        /* Tool Certification Section */
        .tools {
            padding: 6rem 2rem;
            max-width: 1280px;
            margin: 0 auto;
            text-align: center;
        }

        .tools h2 {
            font-size: 40px;
            font-weight: 800;
            margin-bottom: 1rem;
        }

        .tools-subtitle {
            color: var(--text-secondary);
            font-size: 1.25rem;
            margin-bottom: 4rem;
        }

        .tools-grid {
            display: flex;
            justify-content: center;
            gap: 3rem;
            flex-wrap: wrap;
            margin-bottom: 3rem;
        }

        .tool-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1rem;
            opacity: 0.7;
            transition: opacity 0.3s;
        }

        .tool-item:hover {
            opacity: 1;
        }

        .tool-logo {
            width: 80px;
            height: 80px;
            background: var(--bg-secondary);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            color: var(--text-primary);
            border: 1px solid var(--border-light);
            font-size: 1.25rem;
        }

        .tool-name {
            font-weight: 600;
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        .tool-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: #EEF2FF;
            color: var(--brand-indigo);
            padding: 0.75rem 1.5rem;
            border-radius: 20px;
            font-weight: 700;
            font-size: 0.9rem;
            border: 1px solid #C7D2FE;
        }

        /* Pricing Teaser */
        .pricing {
            background: var(--bg-secondary);
            padding: 6rem 2rem;
            text-align: center;
            border-top: 1px solid var(--border-light);
        }

        .pricing-content {
            max-width: 700px;
            margin: 0 auto;
        }

        .pricing h2 {
            font-size: 36px;
            font-weight: 800;
            margin-bottom: 1.5rem;
        }

        .pricing-tag {
            display: inline-block;
            background: white;
            border: 1px solid var(--border-light);
            padding: 1.5rem 3rem;
            border-radius: 12px;
            margin: 2rem 0;
            box-shadow: var(--shadow-md);
        }

        .price-range {
            font-family: var(--font-mono);
            font-size: 2rem;
            color: var(--text-primary);
            font-weight: 700;
        }

        .price-note {
            color: var(--text-muted);
            font-size: 0.9rem;
            margin-top: 0.5rem;
        }

        .pricing-features {
            display: flex;
            justify-content: center;
            gap: 2rem;
            margin: 2rem 0;
            flex-wrap: wrap;
            font-weight: 600;
            color: var(--text-secondary);
        }

        .pricing-features span {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        /* Footer */
        footer {
            background: var(--bg-primary);
            border-top: 1px solid var(--border-light);
            padding: 4rem 2rem 2rem;
        }

        .footer-container {
            max-width: 1280px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1fr;
            gap: 4rem;
            margin-bottom: 3rem;
        }

        .footer-brand p {
            color: var(--text-secondary);
            margin-top: 1rem;
            font-size: 1.1rem;
        }

        .footer-column h4 {
            font-weight: 700;
            margin-bottom: 1.5rem;
            color: var(--text-primary);
        }

        .footer-column ul {
            list-style: none;
        }

        .footer-column li {
            margin-bottom: 0.75rem;
        }

        .footer-column a {
            color: var(--text-secondary);
            text-decoration: none;
            transition: color 0.2s;
        }

        .footer-column a:hover {
            color: var(--brand-indigo);
        }

        .verification-tool {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: #EEF2FF;
            padding: 0.5rem 1rem;
            border-radius: 6px;
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--brand-indigo);
            margin-top: 1rem;
            border: 1px solid #C7D2FE;
        }

        .footer-bottom {
            max-width: 1280px;
            margin: 0 auto;
            padding-top: 2rem;
            border-top: 1px solid var(--border-light);
            display: flex;
            justify-content: space-between;
            color: var(--text-muted);
            font-size: 0.875rem;
        }

        /* Certificate Verification Modal */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
